<div class="ascii-banner" aria-hidden="true">
  <canvas id="ascii-banner-canvas"></canvas>
</div>

<style>
  .ascii-banner {
    position: relative; height: 180px; margin: 0 0 2.2rem;
    border: 1px solid var(--line); border-radius: 6px; overflow: hidden;
    background: #0a0a09; cursor: crosshair;
  }
  .ascii-banner canvas { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }
  @media (prefers-reduced-motion: reduce) { .ascii-banner { display: none; } }
</style>

<script>
  // Mini ASCII renderer (2D canvas) — clin d'œil au renderer ascii-105 de generalintuition.com
  const RAMP = " .`,:;-~=+*<>()[]{}xoahkbdpqwmZO0QLCJUYX#MW&8%B@$";
  const wrap = document.querySelector(".ascii-banner") as HTMLElement | null;
  const cv = document.getElementById("ascii-banner-canvas") as HTMLCanvasElement | null;
  if (wrap && cv && !matchMedia("(prefers-reduced-motion: reduce)").matches) {
    const g = cv.getContext("2d")!;
    let cols = 0, rows = 0, cw = 0, chh = 0;
    const glow: { x: number; y: number; t: number }[] = [];
    let lastStamp = 0;

    const size = () => {
      const r = wrap.getBoundingClientRect();
      const dpr = Math.min(devicePixelRatio || 1, 2);
      cv.width = r.width * dpr; cv.height = r.height * dpr;
      cols = Math.floor(r.width / 9); rows = Math.floor(r.height / 13);
      cw = cv.width / cols; chh = cv.height / rows;
    };
    size();
    new ResizeObserver(size).observe(wrap);

    const hash = (x: number, y: number) => {
      const s = Math.sin(x * 127.1 + y * 311.7) * 43758.5453;
      return s - Math.floor(s);
    };
    const noise = (x: number, y: number) => {
      const xi = Math.floor(x), yi = Math.floor(y), xf = x - xi, yf = y - yi;
      const sx = xf * xf * (3 - 2 * xf), sy = yf * yf * (3 - 2 * yf);
      return (
        hash(xi, yi) * (1 - sx) * (1 - sy) + hash(xi + 1, yi) * sx * (1 - sy) +
        hash(xi, yi + 1) * (1 - sx) * sy + hash(xi + 1, yi + 1) * sx * sy
      );
    };
    const fbm = (x: number, y: number) => {
      let v = 0, a = 0.5;
      for (let k = 0; k < 4; k++) { v += a * noise(x, y); x = x * 2.03 + 11.7; y = y * 2.03 + 11.7; a *= 0.5; }
      return v;
    };

    wrap.addEventListener("pointermove", (e) => {
      const now = performance.now();
      if (now - lastStamp < 25) return;
      lastStamp = now;
      const r = wrap.getBoundingClientRect();
      glow.unshift({ x: (e.clientX - r.left) / r.width, y: (e.clientY - r.top) / r.height, t: now / 1000 });
      if (glow.length > 8) glow.length = 8;
    }, { passive: true });

    const frame = (nowMs: number) => {
      const t = nowMs / 1000;
      g.fillStyle = "#0a0a09"; g.fillRect(0, 0, cv.width, cv.height);
      g.font = `${Math.ceil(chh * 0.95)}px "IBM Plex Mono", monospace`;
      g.textBaseline = "top";
      const alive = glow.filter((p) => t - p.t <= 1);
      for (let y = 0; y < rows; y++) {
        for (let x = 0; x < cols; x++) {
          const u = x / cols, v = y / rows;
          const q = fbm(u * 5 + t * 0.1, v * 2.5 - t * 0.05);
          const r2 = fbm(u * 8 + q * 2 - t * 0.07, v * 4 + q);
          let lum = Math.max(0, r2 * 1.35 - 0.25);
          let ga = 0;
          for (const p of alive) {
            const dx = (u - p.x) * cols * 9, dy = (v - p.y) * rows * 13;
            const d = Math.hypot(dx, dy);
            if (d < 80) ga = Math.max(ga, (1 - d / 80) ** 0.35 * (1 - (t - p.t)));
          }
          lum = Math.min(1, lum + ga * 0.65);
          if (lum < 0.06) continue;
          const ch = RAMP[Math.min(RAMP.length - 1, (lum * RAMP.length) | 0)];
          const warm = q > 0.55;
          const cR = warm ? 220 : 70, cG = warm ? 130 : 170, cB = warm ? 60 : 160;
          g.fillStyle = `rgba(${cR + ga * 35},${cG + ga * 60},${cB + ga * 40},${0.3 + lum * 0.7})`;
          g.fillText(ch, x * cw, y * chh);
        }
      }
      requestAnimationFrame(frame);
    };
    requestAnimationFrame(frame);
  }
</script>
