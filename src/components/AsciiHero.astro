---
// Renderer ASCII WebGL — port du pipeline « ascii-105 » de generalintuition.com
interface Props { scene?: number; ambient?: boolean; image?: string }
const { scene = 0, ambient = false, image } = Astro.props;
---
<div class="canvas-container" data-ascii-scene={scene} data-ascii-ambient={ambient ? "" : undefined} data-ascii-image={image}>
  <canvas></canvas>
</div>

<style>
  .canvas-container {
    position: relative; width: 100%; height: 100%;
    opacity: 0; transition: opacity 1s ease-in-out; will-change: opacity;
    background: #000; cursor: crosshair;
  }
  .canvas-container.active { opacity: 1; }
  .canvas-container canvas { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }
</style>

<script>
  import { initAscii } from "../scripts/ascii";
  for (const el of document.querySelectorAll<HTMLElement>(".canvas-container[data-ascii-scene]")) {
    initAscii(el, Number(el.dataset.asciiScene || 0), el.dataset.asciiImage);
  }
</script>
