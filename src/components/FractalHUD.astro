---
// HUD de coordonnées façon explorateur de fractales — reproduit exactement
// les formules du shader (même horloge performance.now()/1000 = uTime).
interface Props { kind: "mandel" | "julia" }
const { kind } = Astro.props;
---
<div class="fhud" data-kind={kind} aria-hidden="true"></div>

<style>
  .fhud {
    position: absolute; left: 50%; transform: translateX(-50%); bottom: 2rem; z-index: 5;
    pointer-events: none; text-align: center;
    font-size: 0.68rem; letter-spacing: 0.12em; color: var(--dim);
    font-variant-numeric: tabular-nums; white-space: pre;
    text-shadow: 0 0 12px rgba(0, 0, 0, 0.9);
  }
  @media (max-width: 900px) { .fhud { display: none; } }
</style>

<script>
  const el = document.querySelector<HTMLElement>(".fhud");
  if (el) {
    const kind = el.dataset.kind;
    const fmt = (v: number, d = 10) => (v < 0 ? "−" : "+") + Math.abs(v).toFixed(d);
    const tick = () => {
      const t = performance.now() / 1000;
      if (kind === "mandel") {
        // memes formules que sceneMandel : zoom respirant vers la vallee des hippocampes
        const zt = 0.5 - 0.5 * Math.cos(t * 0.06);
        const scale = Math.exp(0.2 + (-6.2 - 0.2) * zt);
        const zoom = Math.exp(0.2) / scale;
        el.textContent =
          `RE ${fmt(-0.743643)}   IM ${fmt(0.131825)}i\n` +
          `ZOOM ×${zoom.toFixed(zoom < 100 ? 1 : 0).padStart(6, " ")}   ROT ${((t * 0.02 * 180 / Math.PI) % 360).toFixed(1)}°`;
      } else {
        // sceneJulia : c = 0.7885·e^(iθ)
        const live = (window as any).__juliaC;
        const th = t * 0.12;
        const cr = live ? live.cr : 0.7885 * Math.cos(th);
        const ci = live ? live.ci : 0.7885 * Math.sin(th);
        const zoom = Math.exp(0.30 + (-1.0 - 0.30) * (0.5 - 0.5 * Math.cos(t * 0.05)));
        const px = 0.30 * Math.sin(t * 0.031) * (1 - zoom * 0.6);
        const py = 0.24 * Math.sin(t * 0.043 + 1.7) * (1 - zoom * 0.6);
        const mode = live?.manual ? "MANUEL — c suit votre souris" : "ORBITE AUTO";
        el.textContent =
          `c ${fmt(cr, 7)} ${fmt(ci, 7)}i   ${mode}\n` +
          `POS ${fmt(px, 4)} ${fmt(py, 4)}i   ZOOM ×${(Math.exp(0.30) / zoom).toFixed(2)}`;
      }
      requestAnimationFrame(tick);
    };
    if (!matchMedia("(prefers-reduced-motion: reduce)").matches) requestAnimationFrame(tick);
  }
</script>
