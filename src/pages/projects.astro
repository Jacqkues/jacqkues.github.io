---
import Base from "../layouts/Base.astro";
import AsciiHero from "../components/AsciiHero.astro";

const projects = [
  {
    href: "/67",
    name: "67 Tournament",
    tagline: "Compteur de six-sevens en computer vision — 30 secondes, webcam, leaderboard.",
    stack: "MediaPipe · Canvas · Vanilla JS",
  },
];
---
<Base title="Portfolio | Jacques">
  <main class="page">
    <div class="eyebrow">Portfolio</div>
    <h1>Projects</h1>
    <div class="banner"><AsciiHero scene={2} /></div>
    <ol class="list">
      {projects.map((p, i) => (
        <li>
          <a href={p.href}>
            <span class="num">{String(i + 1).padStart(2, "0")}</span>
            <span class="body">
              <span class="name">{p.name}</span>
              <span class="tagline">{p.tagline}</span>
            </span>
            <span class="stack">{p.stack}</span>
          </a>
        </li>
      ))}
    </ol>
    <p class="more">
      More on <a class="ln" href="https://github.com/Jacqkues">GitHub</a>.
    </p>
  </main>
</Base>

<style>
  .banner { height: 240px; border: 1px solid var(--line); margin: 2.5rem 0; }
  .list { list-style: none; padding: 0; margin: 0 0 2.5rem; }
  .list li { border-bottom: 1px solid var(--line); }
  .list a {
    display: flex; align-items: baseline; gap: 1.4rem;
    padding: 1.1rem 0.2rem;
    transition: background 0.2s;
  }
  .list a:hover { background: #0c0c0c; }
  .num { color: var(--subtle); font-size: 0.72rem; letter-spacing: 0.1em; }
  .body { flex: 1; display: flex; flex-direction: column; gap: 0.2rem; }
  .name { color: var(--ink); }
  .list a:hover .name { text-decoration: underline; text-underline-offset: 3px; }
  .tagline { color: var(--dim); font-size: 0.8rem; }
  .stack {
    font-size: 0.62rem; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--subtle); white-space: nowrap;
  }
  .more { color: var(--dim); }
  .ln { color: var(--ink); text-decoration: underline; text-underline-offset: 3px; text-decoration-color: var(--subtle); }
  .ln:hover { text-decoration-color: var(--ink); }
  @media (max-width: 40rem) { .stack { display: none; } }
</style>
