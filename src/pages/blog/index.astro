---
import Base from "../../layouts/Base.astro";
import RawShader from "../../components/RawShader.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
// #5 — graine de marbrure derivee du titre : chaque article a son encre
const seedOf = (s: string) =>
  ([...s].reduce((a, c) => (a * 31 + c.charCodeAt(0)) % 9973, 7) / 9973) * 10;
---
<Base title="Blog | Jacques">
  <main class="page">
    <div class="eyebrow">Blog Archive</div>
    <h1>Writing</h1>
    <div class="list">
      {posts.map((p, i) => (
        <a class="card" href={`/blog/${p.id}`}>
          <div class="marb"><RawShader scene={4} seed={seedOf(p.data.title)} trailRad={0.08} /></div>
          <div class="meta">
            <span class="idx">{String(i + 1).padStart(2, "0")}</span>
            <h2>{p.data.title}</h2>
            <p class="post-meta">{fmt(p.data.publishDate)}</p>
            <p class="desc">{p.data.description}</p>
            <span class="read">Read Post →</span>
          </div>
        </a>
      ))}
    </div>
  </main>
</Base>

<style>
  .list { margin-top: 2.5rem; display: flex; flex-direction: column; }
  .card {
    display: grid; grid-template-columns: minmax(220px, 34%) 1fr; gap: 1.6rem;
    border-top: 1px solid var(--line); padding: 1.6rem 0;
  }
  .card:last-child { border-bottom: 1px solid var(--line); }
  .marb { position: relative; aspect-ratio: 16/10; border: 1px solid var(--line); overflow: hidden; }
  .idx { font-size: 0.7rem; color: var(--subtle); }
  .card h2 { font-size: 1.3rem; margin-top: 0.4rem; }
  .card:hover h2 { text-decoration: underline; text-underline-offset: 4px; text-decoration-color: var(--subtle); }
  .post-meta { margin-top: 0.4rem; }
  .desc { margin-top: 0.7rem; color: var(--dim); max-width: 46rem; font-size: 0.88rem; }
  .read {
    display: inline-block; margin-top: 0.9rem;
    font-size: 0.68rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink);
    border-bottom: 1px solid var(--subtle); padding-bottom: 0.15rem;
  }
  .card:hover .read { border-color: var(--ink); }
  @media (max-width: 720px) { .card { grid-template-columns: 1fr; } }
</style>
