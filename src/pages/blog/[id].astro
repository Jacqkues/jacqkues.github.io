---
import Base from "../../layouts/Base.astro";
import RawShader from "../../components/RawShader.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({ params: { id: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const fmt = post.data.publishDate.toLocaleDateString("en-US", {
  year: "numeric", month: "long", day: "numeric",
});
---
<Base title={`${post.data.title} | Jacques`} description={post.data.description}>
  <main class="page">
    <div class="banner"><RawShader scene={8} trailRad={0.028} /></div>
    <article>
      <header class="post-head">
        <p class="post-meta">{fmt}</p>
        <h1>{post.data.title}</h1>
        <div class="tags">
          {post.data.tags.map((t) => <a class="tag" href={`/tags/${t.toLowerCase()}`}>#{t}</a>)}
        </div>
      </header>
      <div class="prose">
        <Content />
      </div>
    </article>
  </main>
</Base>

<style>
  .banner { height: 260px; border: 1px solid var(--line); margin-bottom: 2.5rem; }
  article { max-width: 46rem; }
  .post-head { margin-bottom: 2.5rem; }
  .post-head h1 { margin-top: 0.6rem; }
  .tags { margin-top: 1rem; display: flex; gap: 0.5rem; }
</style>
