---
import Base from "../../layouts/Base.astro";
import AsciiHero from "../../components/AsciiHero.astro";
import FractalHUD from "../../components/FractalHUD.astro";
import RawShader from "../../components/RawShader.astro";
import { VARIANTS } from "../../data/lab";

export function getStaticPaths() {
  return VARIANTS.map((v, i) => ({
    params: { variant: v.slug },
    props: { v, prev: VARIANTS[(i + VARIANTS.length - 1) % VARIANTS.length], next: VARIANTS[(i + 1) % VARIANTS.length], idx: i },
  }));
}
const { v, prev, next, idx } = Astro.props;
---
<Base title={`${v.name} — Lab | Jacques`} description={v.tagline} fullBleed>
  <main>
    <section class="hero">
      {v.raw !== undefined ? <RawShader scene={v.raw} trailRad={v.trailRad ?? 0.11} /> : <AsciiHero scene={v.scene} image={v.image} ambient />}
      <div class="hero-copy">
        <div class="eyebrow">Lab {String(idx + 1).padStart(2, "0")} — {v.name}</div>
        <h1>Jacques Dumora.<br />ML &amp; Data Engineer.</h1>
        <p>{v.tagline}</p>
      </div>
      {v.hud && <FractalHUD kind={v.hud} />}
      <div class="lab-nav">
        <a href={`/lab/${prev.slug}`}>← {prev.name}</a>
        <a href="/lab">Lab</a>
        <a href={`/lab/${next.slug}`}>{next.name} →</a>
      </div>
    </section>
  </main>
</Base>

<style>
  .hero { position: relative; height: 100svh; }
  .hero::after {
    content: ""; position: absolute; inset: auto 0 0 0; height: 42%; z-index: 4;
    pointer-events: none;
    background: linear-gradient(to top, rgba(0,0,0,0.8), rgba(0,0,0,0));
  }
  .hero-copy {
    position: absolute; left: clamp(1rem, 3vw, 2rem); bottom: 2rem; z-index: 5;
    pointer-events: none; max-width: 46rem;
  }
  .hero-copy .eyebrow { margin-bottom: 0.8rem; }
  .hero-copy h1 { font-size: clamp(1.8rem, 5vw, 3.4rem); text-shadow: 0 0 30px rgba(0,0,0,0.85); }
  .hero-copy p { margin-top: 0.8rem; color: var(--dim); font-size: 0.85rem; }
  .lab-nav {
    position: absolute; right: clamp(1rem, 3vw, 2rem); bottom: 2rem; z-index: 5;
    display: flex; gap: 1.4rem;
    font-size: 0.68rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--dim);
  }
  .lab-nav a:hover { color: var(--ink); }
</style>
