---
import Base from "../../layouts/Base.astro";
import AsciiHero from "../../components/AsciiHero.astro";
import RawShader from "../../components/RawShader.astro";
import { VARIANTS } from "../../data/lab";
---
<Base title="Lab | Jacques" description="Variantes génératives de la landing page — shaders ASCII WebGL.">
  <main class="page">
    <div class="eyebrow">Lab — shaders ASCII</div>
    <h1>Une landing, {VARIANTS.length} atmosphères.</h1>
    <p class="sub">Fragment shaders — rendus ASCII ou pleine résolution.
    Survolez pour dessiner, cliquez pour voir la landing complète.</p>
    <div class="grid">
      {VARIANTS.map((v, i) => (
        <a class="cell" href={`/lab/${v.slug}`}>
          <div class="cv">{v.raw !== undefined ? <RawShader scene={v.raw} trailRad={v.trailRad ?? 0.11} /> : <AsciiHero scene={v.scene} image={v.image} />}</div>
          <div class="cap">
            <span>{String(i + 1).padStart(2, "0")} · {v.name}</span>
            <span class="tl">{v.tagline}</span>
          </div>
        </a>
      ))}
    </div>
  </main>
</Base>

<style>
  .sub { color: var(--dim); margin-top: 0.8rem; max-width: 40rem; font-size: 0.85rem; }
  .grid {
    margin-top: 2.5rem;
    display: grid; gap: 1px; background: var(--line); border: 1px solid var(--line);
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  }
  .cell { position: relative; aspect-ratio: 16/10; background: #000; overflow: hidden; display: block; }
  .cv { position: absolute; inset: 0; }
  .cap {
    position: absolute; left: 0.9rem; right: 0.9rem; bottom: 0.75rem; z-index: 4; pointer-events: none;
    display: flex; flex-direction: column; gap: 0.15rem;
    font-size: 0.68rem; letter-spacing: 0.14em; text-transform: uppercase;
    text-shadow: 0 0 12px rgba(0,0,0,0.9);
  }
  .tl { color: var(--dim); text-transform: none; letter-spacing: 0.04em; }
</style>
