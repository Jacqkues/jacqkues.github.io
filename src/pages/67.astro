---
import Base from "../layouts/Base.astro";
---
<Base title="67 Tournament — Jacques" description="Compteur de six-sevens en computer vision — 30 secondes, tournoi.">
  <main>
    <div class="page">
      <p class="eyebrow">Computer vision — 30 seconds</p>
      <h1>67 Tournament</h1>
      <p class="sub">Deux mains face caméra. Alterne haut / bas. Chaque inversion compte pour un six-seven.</p>

      <div class="stage">
        <video id="video" playsinline></video>
        <canvas id="canvas" width="960" height="720"></canvas>
        <div class="hud">
          <div class="hud-top">
            <div class="metric"><span class="label">Time</span><span class="value" id="timer">30.0</span></div>
            <div class="metric right"><span class="label">Six sevens</span><span class="value" id="count">0</span></div>
          </div>
          <div class="status" id="status">Chargement du modèle…</div>
        </div>
        <div class="flash" id="flash">67</div>
      </div>

      <div class="controls">
        <input type="text" id="playerName" placeholder="Nom du joueur" maxlength="20" aria-label="Nom du joueur" />
        <button id="startBtn" disabled>Start</button>
      </div>

      <div class="board">
        <h2>Leaderboard <button id="resetBtn">Reset</button></h2>
        <ol id="board"></ol>
        <div class="empty" id="emptyMsg">Aucun score — sois le premier.</div>
      </div>
    </div>
  </main>
</Base>

<style>
  .page { max-width: 46rem; }
  .sub { color: var(--dim); font-size: 0.85rem; margin: 0.4rem 0 2.2rem; }

  .stage {
    position: relative;
    width: 100%;
    aspect-ratio: 4/3;
    border: 1px solid var(--line);
    background: #0c0c0c;
    overflow: hidden;
  }
  video { display: none; }
  canvas { width: 100%; height: 100%; display: block; }

  .hud {
    position: absolute; inset: 0; pointer-events: none;
    display: flex; flex-direction: column; justify-content: space-between;
  }
  .hud-top {
    display: flex; justify-content: space-between; align-items: flex-start;
    padding: 0.9rem 1.1rem;
    mix-blend-mode: difference;
  }
  .metric { font-variant-numeric: tabular-nums; }
  .metric .label {
    display: block; font-size: 0.62rem; letter-spacing: 0.22em;
    text-transform: uppercase; color: #bbb;
  }
  .metric .value { font-size: 2.1rem; line-height: 1.1; color: #fff; }
  .metric.right { text-align: right; }
  .status {
    padding: 0.7rem 1.1rem;
    font-size: 0.68rem; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--dim);
    border-top: 1px solid var(--line);
    background: rgba(0,0,0,0.55);
  }
  .flash {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: clamp(5rem, 20vw, 9rem);
    letter-spacing: -0.02em;
    color: var(--ink);
    opacity: 0;
    mix-blend-mode: difference;
  }
  .flash.show { animation: pop 0.32s ease-out; }
  @keyframes pop {
    0% { opacity: 1; transform: scale(0.6); }
    100% { opacity: 0; transform: scale(1.25); }
  }
  @media (prefers-reduced-motion: reduce) {
    .flash.show { animation: none; opacity: 0; }
  }

  .controls {
    display: flex; gap: 0; margin: 1.6rem 0 3rem;
    border: 1px solid var(--line);
  }
  input[type="text"] {
    flex: 1; min-width: 0;
    background: transparent; color: var(--ink);
    border: none; outline: none;
    font-family: var(--mono); font-weight: 300; font-size: 0.85rem;
    padding: 0.85rem 1.1rem;
    letter-spacing: 0.05em;
  }
  input[type="text"]::placeholder { color: var(--subtle); text-transform: uppercase; font-size: 0.72rem; letter-spacing: 0.18em; }
  button {
    font-family: var(--mono); font-weight: 300;
    font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase;
    padding: 0.85rem 1.6rem;
    cursor: pointer;
    background: transparent; color: var(--dim);
    border: none; border-left: 1px solid var(--line);
    transition: color 0.2s, background 0.2s;
  }
  button:hover:not(:disabled) { color: var(--bg); background: var(--ink); }
  button:focus-visible { outline: 1px solid var(--ink); outline-offset: -3px; color: var(--ink); }
  button:disabled { color: var(--line); cursor: not-allowed; }
  #startBtn { color: var(--ink); }

  .board h2 {
    font-weight: 300; font-size: 0.68rem; letter-spacing: 0.22em;
    text-transform: uppercase; color: var(--dim);
    border-top: 1px solid var(--line);
    padding-top: 1.4rem; margin-bottom: 1rem;
    display: flex; justify-content: space-between; align-items: baseline;
  }
  .board h2 button { border: 1px solid var(--subtle); padding: 0.25rem 0.8rem; font-size: 0.62rem; }
  .board ol { list-style: none; padding: 0; counter-reset: rank; }
  .board :global(li) {
    counter-increment: rank;
    display: flex; align-items: baseline; gap: 1rem;
    padding: 0.55rem 0.2rem;
    border-bottom: 1px solid var(--line);
    font-size: 0.85rem;
  }
  .board :global(li)::before {
    content: counter(rank, decimal-leading-zero);
    color: var(--subtle); font-size: 0.72rem; letter-spacing: 0.1em;
  }
  .board :global(.name) { flex: 1; letter-spacing: 0.05em; }
  .board :global(.score) { font-variant-numeric: tabular-nums; color: var(--ink); }
  .board :global(li:first-child .name)::after {
    content: "best"; margin-left: 0.8rem;
    font-size: 0.6rem; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--dim); border: 1px solid var(--subtle); padding: 0.1rem 0.5rem;
  }
  .empty { color: var(--subtle); font-size: 0.8rem; padding: 0.4rem 0.2rem; }
</style>

<script src="https://cdn.jsdelivr.net/npm/@mediapipe/hands/hands.js" is:inline></script>
<script src="https://cdn.jsdelivr.net/npm/@mediapipe/camera_utils/camera_utils.js" is:inline></script>
<script is:inline>
(() => {
  const video = document.getElementById('video');
  const canvas = document.getElementById('canvas');
  const timerEl = document.getElementById('timer');
  const countEl = document.getElementById('count');
  const statusEl = document.getElementById('status');
  const flashEl = document.getElementById('flash');
  const startBtn = document.getElementById('startBtn');
  const resetBtn = document.getElementById('resetBtn');
  const boardEl = document.getElementById('board');
  const emptyMsg = document.getElementById('emptyMsg');
  const nameInput = document.getElementById('playerName');

  const DURATION = 30000;
  // Écart vertical minimal (fraction de la hauteur image) entre les 2 mains
  // pour valider une position haute/basse — filtre le bruit.
  const GAP = 0.10;
  const MAX_DROPS = 24;

  let running = false;
  let count = 0;
  let endTime = 0;
  let lastPose = null; // 'L' = gauche en haut, 'R' = droite en haut
  let latestHands = [];

  // ---------- Leaderboard ----------
  function loadBoard() {
    const scores = JSON.parse(localStorage.getItem('scores67') || '[]');
    scores.sort((a, b) => b.score - a.score);
    boardEl.innerHTML = scores.slice(0, 10).map(s =>
      `<li><span class="name">${escapeHtml(s.name)}</span><span class="score">${s.score}</span></li>`).join('');
    emptyMsg.style.display = scores.length ? 'none' : 'block';
  }
  function saveScore(name, score) {
    const scores = JSON.parse(localStorage.getItem('scores67') || '[]');
    scores.push({ name, score, date: Date.now() });
    localStorage.setItem('scores67', JSON.stringify(scores));
    loadBoard();
  }
  function escapeHtml(s) {
    return s.replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
  }
  resetBtn.onclick = () => { localStorage.removeItem('scores67'); loadBoard(); };
  loadBoard();

  // ---------- WebGL : vidéo + ondes liquides qui suivent les mains ----------
  const gl = canvas.getContext('webgl', { antialias: false });
  const VERT = `
    attribute vec2 aPos;
    varying vec2 vUv;
    void main() {
      vUv = aPos * 0.5 + 0.5;
      gl_Position = vec4(aPos, 0.0, 1.0);
    }`;
  const FRAG = `
    precision highp float;
    varying vec2 vUv;
    uniform sampler2D uTex;
    uniform float uTime;
    uniform float uAspect;
    uniform vec2 uHands[2];
    uniform int uHandCount;
    uniform vec4 uDrops[${MAX_DROPS}]; // x, y (origine haut-gauche, miroir), naissance, amplitude
    uniform float uEnergy; // 0 → calme, 1 → furie (cadence des reps)

    void main() {
      // coordonnées écran, origine haut-gauche (comme MediaPipe, déjà en miroir)
      vec2 s = vec2(vUv.x, 1.0 - vUv.y);

      vec2 disp = vec2(0.0);
      float crest = 0.0;

      // gouttes : anneaux qui s'étendent et s'amortissent, réfraction de la vidéo
      for (int i = 0; i < ${MAX_DROPS}; i++) {
        float birth = uDrops[i].z;
        if (birth < 0.0) continue;
        float t = uTime - birth;
        if (t > 2.2) continue;
        float amp = uDrops[i].w;
        vec2 p = s - uDrops[i].xy;
        p.x *= uAspect;
        float d = length(p);
        float r = 0.06 + t * 0.38;
        float ring = exp(-abs(d - r) * 34.0) * exp(-t * 2.4);
        float boost = 1.0 + uEnergy * 1.6;
        disp += normalize(p + 1e-5) * sin((d - r) * 90.0) * ring * 0.028 * amp * boost;
        crest += ring * amp * 0.55 * boost;
      }

      // halo liquide permanent sous chaque paume — gonfle avec l'énergie
      for (int i = 0; i < 2; i++) {
        if (i >= uHandCount) break;
        vec2 p = s - uHands[i];
        p.x *= uAspect;
        float d = length(p);
        float g = exp(-d * d * (90.0 - uEnergy * 55.0));
        float amp2 = 0.010 + uEnergy * 0.020;
        disp += vec2(sin(uTime * 4.0 + d * 40.0), cos(uTime * 3.3 + d * 34.0)) * g * amp2;
        crest += g * (0.30 + uEnergy * 0.55);
      }

      // haute énergie : toute l'image ondule
      float wob = uEnergy * uEnergy;
      disp += vec2(
        sin(s.y * 22.0 + uTime * 9.0),
        cos(s.x * 19.0 + uTime * 8.0)
      ) * wob * 0.012;

      // échantillonnage miroir + réfraction
      vec2 tuv = vec2(1.0 - (s.x + disp.x), s.y + disp.y);
      tuv = clamp(tuv, 0.001, 0.999);
      vec3 col = texture2D(uTex, tuv).rgb;

      // noir & blanc — le contraste durcit avec l'énergie
      float g = dot(col, vec3(0.299, 0.587, 0.114));
      g = pow(g, 1.15 + uEnergy * 0.9) * (1.06 + uEnergy * 0.35);

      // battement global à haute énergie
      g *= 1.0 + sin(uTime * 14.0) * uEnergy * uEnergy * 0.12;

      // crêtes blanches des ondes + vignettage qui se resserre
      vec2 vc = vUv - 0.5;
      float vig = 1.0 - dot(vc, vc) * (0.55 + uEnergy * 0.9);
      float outv = clamp(g * vig + crest, 0.0, 1.0);
      gl_FragColor = vec4(vec3(outv), 1.0);
    }`;

  function compile(type, src) {
    const sh = gl.createShader(type);
    gl.shaderSource(sh, src);
    gl.compileShader(sh);
    if (!gl.getShaderParameter(sh, gl.COMPILE_STATUS)) throw new Error(gl.getShaderInfoLog(sh));
    return sh;
  }
  const prog = gl.createProgram();
  gl.attachShader(prog, compile(gl.VERTEX_SHADER, VERT));
  gl.attachShader(prog, compile(gl.FRAGMENT_SHADER, FRAG));
  gl.linkProgram(prog);
  gl.useProgram(prog);

  const buf = gl.createBuffer();
  gl.bindBuffer(gl.ARRAY_BUFFER, buf);
  gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,-1, 3,-1, -1,3]), gl.STATIC_DRAW);
  const aPos = gl.getAttribLocation(prog, 'aPos');
  gl.enableVertexAttribArray(aPos);
  gl.vertexAttribPointer(aPos, 2, gl.FLOAT, false, 0, 0);

  const tex = gl.createTexture();
  gl.bindTexture(gl.TEXTURE_2D, tex);
  gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.CLAMP_TO_EDGE);
  gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.CLAMP_TO_EDGE);
  gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.LINEAR);
  gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.LINEAR);

  const U = n => gl.getUniformLocation(prog, n);
  const uTime = U('uTime'), uAspect = U('uAspect'), uHandsLoc = U('uHands'),
        uHandCount = U('uHandCount'), uDropsLoc = U('uDrops'), uEnergyLoc = U('uEnergy');

  // Énergie : cadence des reps sur les 3 dernières secondes.
  // ~1 rep/s → faible, 4+ reps/s → furie. Lissée pour monter vite, retomber doux.
  const repTimes = [];
  let energy = 0;
  function currentEnergy() {
    const t = now();
    while (repTimes.length && t - repTimes[0] > 3) repTimes.shift();
    const rate = repTimes.length / 3; // reps par seconde
    const target = Math.min(1, rate / 4);
    energy += (target - energy) * (target > energy ? 0.12 : 0.015);
    return energy;
  }

  // gouttes : tampon circulaire, x/y écran (miroir, origine haut-gauche), naissance, amplitude
  const drops = new Float32Array(MAX_DROPS * 4).fill(-1);
  let dropIdx = 0;
  const t0 = performance.now();
  const now = () => (performance.now() - t0) / 1000;

  function spawnDrop(x, y, amp) {
    drops[dropIdx * 4] = x;
    drops[dropIdx * 4 + 1] = y;
    drops[dropIdx * 4 + 2] = now();
    drops[dropIdx * 4 + 3] = amp;
    dropIdx = (dropIdx + 1) % MAX_DROPS;
  }

  // gouttelettes quand la main bouge vite
  const prevHands = [null, null];
  const lastSpawn = [0, 0];
  function trackHandDrops(hands) {
    const t = now();
    for (let i = 0; i < hands.length && i < 2; i++) {
      const h = hands[i];
      const prev = prevHands[i];
      if (prev) {
        const speed = Math.hypot(h.sx - prev.sx, h.sy - prev.sy);
        if (speed > 0.02 && t - lastSpawn[i] > 0.12) {
          spawnDrop(h.sx, h.sy, Math.min(1.0, speed * 18));
          lastSpawn[i] = t;
        }
      }
      prevHands[i] = h;
    }
    for (let i = hands.length; i < 2; i++) prevHands[i] = null;
  }

  function render(image, hands) {
    gl.viewport(0, 0, canvas.width, canvas.height);
    gl.bindTexture(gl.TEXTURE_2D, tex);
    gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, gl.RGBA, gl.UNSIGNED_BYTE, image);
    gl.uniform1f(uTime, now());
    gl.uniform1f(uAspect, canvas.width / canvas.height);
    const hArr = new Float32Array(4);
    for (let i = 0; i < hands.length && i < 2; i++) { hArr[i*2] = hands[i].sx; hArr[i*2+1] = hands[i].sy; }
    gl.uniform2fv(uHandsLoc, hArr);
    gl.uniform1i(uHandCount, Math.min(hands.length, 2));
    gl.uniform4fv(uDropsLoc, drops);
    gl.uniform1f(uEnergyLoc, currentEnergy());
    gl.drawArrays(gl.TRIANGLES, 0, 3);
  }

  // ---------- MediaPipe ----------
  const mpHands = new Hands({ locateFile: f => `https://cdn.jsdelivr.net/npm/@mediapipe/hands/${f}` });
  mpHands.setOptions({ maxNumHands: 2, modelComplexity: 0, minDetectionConfidence: 0.6, minTrackingConfidence: 0.5 });
  mpHands.onResults(results => {
    latestHands = [];
    if (results.multiHandLandmarks) {
      for (const lm of results.multiHandLandmarks) {
        const x = (lm[0].x + lm[9].x) / 2;
        const y = (lm[0].y + lm[9].y) / 2;
        // sx/sy : coordonnées écran (image en miroir)
        latestHands.push({ x, y, sx: 1 - x, sy: y });
      }
    }
    trackHandDrops(latestHands);
    render(results.image, latestHands);
    if (running) detectRep();
  });
  const camera = new Camera(video, {
    onFrame: async () => { await mpHands.send({ image: video }); },
    width: 960, height: 720
  });
  camera.start().then(() => {
    statusEl.textContent = 'Prêt — deux mains face caméra';
    startBtn.disabled = false;
  }).catch(() => {
    statusEl.textContent = 'Caméra inaccessible — autorise la webcam et recharge';
  });

  // Un rep = les deux mains inversent leur position verticale (le geste 6-7).
  function detectRep() {
    if (latestHands.length < 2) { statusEl.textContent = 'Montre tes deux mains'; return; }
    statusEl.textContent = 'Go';

    const [a, b] = latestHands;
    const left  = a.sx < b.sx ? a : b;
    const right = a.sx < b.sx ? b : a;

    let pose = null;
    if (left.sy < right.sy - GAP) pose = 'L';
    else if (right.sy < left.sy - GAP) pose = 'R';

    if (pose && lastPose && pose !== lastPose) {
      count++;
      countEl.textContent = count;
      repTimes.push(now());
      // onde de choc au centre des deux mains, amplifiée par l'énergie
      spawnDrop((left.sx + right.sx) / 2, (left.sy + right.sy) / 2, 2.2 + energy * 2.0);
      flashEl.classList.remove('show');
      void flashEl.offsetWidth;
      flashEl.classList.add('show');
      flashEl.textContent = count % 2 ? '6' : '7';
    }
    if (pose) lastPose = pose;
  }

  // ---------- Timer / run ----------
  startBtn.onclick = () => {
    const name = nameInput.value.trim() || 'Anonyme';
    count = 0;
    countEl.textContent = '0';
    lastPose = null;
    startBtn.disabled = true;
    nameInput.disabled = true;

    let cd = 3;
    statusEl.textContent = '';
    flashEl.textContent = cd;
    flashEl.classList.remove('show'); void flashEl.offsetWidth; flashEl.classList.add('show');
    const cdInt = setInterval(() => {
      cd--;
      if (cd > 0) {
        flashEl.textContent = cd;
        flashEl.classList.remove('show'); void flashEl.offsetWidth; flashEl.classList.add('show');
      } else {
        clearInterval(cdInt);
        running = true;
        endTime = performance.now() + DURATION;
        requestAnimationFrame(tick);
      }
    }, 1000);

    function tick(t) {
      const remaining = Math.max(0, endTime - t);
      timerEl.textContent = (remaining / 1000).toFixed(1);
      if (remaining > 0 && running) {
        requestAnimationFrame(tick);
      } else {
        running = false;
        timerEl.textContent = '0.0';
        statusEl.textContent = `Terminé — ${name} : ${count} six-sevens`;
        saveScore(name, count);
        startBtn.disabled = false;
        nameInput.disabled = false;
      }
    }
  };
})();
</script>
