---
import Base from "../layouts/Base.astro";
---
<Base title="Contact | Jacques">
  <main class="page">
    <div class="eyebrow">Contact</div>
    <h1>Get in touch</h1>
    <div class="prose">
      <p>
        Thank you for reaching out! Whether you have a question, a suggestion, or just want to share
        your thoughts, I'm all ears. Feel free to get in touch through any of the methods below:
      </p>
      <h2>Email</h2>
      <p>
        Feel free to drop me an email at <a href="mailto:jacq.dumora@gmail.com">jacq.dumora@gmail.com</a>, and I'll do my best to respond as soon as possible.
      </p>
      <h2>Social Media</h2>
      <p>
        Connect with me on social media as well. Find me on <a href="https://x.com/_jacqD">Twitter</a> or <a href="https://www.linkedin.com/in/jacques-dumora">LinkedIn</a>.
      </p>
    </div>
  </main>
</Base>

<style>
  .prose { margin-top: 2rem; max-width: 46rem; }
</style>
